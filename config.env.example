# ============================================
# 心语机器人配置文件示例
# ============================================

# ============================================
# LLM API 配置
# ============================================
# 支持多种 LLM 服务：OpenAI、通义千问、其他兼容接口
# 优先使用 LLM_API_KEY，也支持 DASHSCOPE_API_KEY 和 OPENAI_API_KEY（兼容旧版本）
LLM_API_KEY=your_llm_api_key_here
# DASHSCOPE_API_KEY=your_dashscope_api_key_here  # 阿里云通义千问API密钥（可选，与LLM_API_KEY二选一）
# OPENAI_API_KEY=your_openai_api_key_here  # OpenAI API密钥（可选，与LLM_API_KEY二选一）

# LLM API 基础URL
# 智谱: https://open.bigmodel.cn/api/paas/v4
# OpenAI: https://api.openai.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 默认模型名称
# 智谱: glm-5.1, glm-4-flash, glm-4-plus
# OpenAI: gpt-4, gpt-3.5-turbo
# 通义千问: qwen-plus, qwen-turbo
DEFAULT_MODEL=glm-5.1

# ============================================
# 数据库配置
# ============================================
# 数据库类型: mysql, sqlite, 或留空自动检测（MySQL不可用时自动回退SQLite）
DB_TYPE=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=emotional_chat

# ============================================
# 插件系统配置（新增）
# ============================================

# 天气 API 配置
# 选项1：OpenWeatherMap API
OPENWEATHER_API_KEY=your_openweather_api_key

# 选项2：和风天气 API
# HEFENG_WEATHER_API_KEY=your_hefeng_api_key

# 新闻 API 配置
NEWS_API_KEY=your_news_api_key

# ============================================
# 向量数据库配置
# ============================================
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ============================================
# LangChain 配置
# ============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
