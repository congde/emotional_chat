# ============================================
# 心语机器人配置文件示例
# ============================================

# ============================================
# LLM API 配置
# ============================================
# 模型网关（LLM Harness）与 Nous Hermes Agent 类似：只改 base_url + key + 模型名即可切换提供商，
# 无需改业务代码。参考: https://github.com/nousresearch/hermes-agent
# 支持多种 LLM 服务：智谱 GLM、OpenAI、通义千问、其他 OpenAI 兼容接口
# 优先使用 LLM_API_KEY，也支持 DASHSCOPE_API_KEY 和 OPENAI_API_KEY（兼容旧版本）
LLM_API_KEY=your_zhipu_api_key_here
# DASHSCOPE_API_KEY=your_dashscope_api_key_here  # 阿里云通义千问（可选）
# OPENAI_API_KEY=your_openai_api_key_here  # OpenAI（可选）

# LLM API 基础URL
# 智谱: https://open.bigmodel.cn/api/paas/v4
# OpenAI: https://api.openai.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 默认模型名称
# 智谱: glm-5.1, glm-4-flash, glm-4-plus
# OpenAI: gpt-4, gpt-3.5-turbo
# 通义千问: qwen-plus, qwen-turbo
DEFAULT_MODEL=glm-5.1

# 自动化评估引擎使用的模型（可选；不设则与 DEFAULT_MODEL 相同）
# EVALUATION_MODEL=glm-5.1

# ============================================
# 数据库配置
# ============================================
# 真实密码请写在项目根目录的 config.env（已 .gitignore），勿在此示例文件中填写
# 数据库类型: mysql, sqlite, 或留空自动检测（MySQL 不可用时自动回退 SQLite）
DB_TYPE=
# 无 MySQL 时也可强制 SQLite：
# USE_SQLITE=1
# SQLITE_PATH=./emotional_chat_local.db
# USE_SQLITE_FALLBACK=0
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=emotional_chat

# ============================================
# 插件系统配置（新增）
# ============================================

# 天气 API 配置
# 选项1：OpenWeatherMap API
OPENWEATHER_API_KEY=your_openweather_api_key

# 选项2：和风天气 API
# HEFENG_WEATHER_API_KEY=your_hefeng_api_key

# 新闻 API 配置
NEWS_API_KEY=your_news_api_key

# ============================================
# 向量数据库配置
# ============================================
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 前端 CORS（逗号分隔多个来源）。不设则默认放行 localhost:3000 / 127.0.0.1:3000 等
# FRONTEND_ORIGINS=http://192.168.1.10:3000
# 仅调试：允许任意来源（关闭 credentials 兼容模式）
# CORS_ALLOW_ALL=0

# ============================================
# Hermes 风格工作区自动化（对齐 https://github.com/nousresearch/hermes-agent 的工具/MCP 思路）
# ============================================
# 总开关：1 时注册 hermes_dispatch 工具，并暴露 /hermes/* API
# HERMES_TOOLS_ENABLED=0
# 书稿、drawio、导出图等所在目录（必须存在）；所有文件操作仅限该目录内
# HERMES_WORKSPACE_ROOT=D:/work/my_book_project
# 是否允许抓取 https 网页（建议配合白名单）
# HERMES_WEB_FETCH_ENABLED=0
# 可选：仅允许访问这些域（逗号分隔），留空则不做域名限制（仍限制体积）
# HERMES_WEB_ALLOWLIST=example.com,api.github.com
# HERMES_WEB_MAX_BYTES=524288
# Figma 只读元数据（画布编辑请用 Figma 客户端或 Plugin API）
# FIGMA_ACCESS_TOKEN=
# 单行 cmd（cwd=工作区），禁止管道/多语句/powershell 等（高风险，默认关）
# HERMES_SHELL_ENABLED=0
# HERMES_SHELL_TIMEOUT_SEC=60

# ============================================
# LangChain 配置
# ============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
