        <mxCell id="result" value="结果" style="swimlane;whiteSpace=wrap;html=1;rounded=1;startSize=34;arcSize=10;swimlaneFillColor=none;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="650" y="270" width="130" height="170" as="geometry" />
        </mxCell>
        <mxCell id="result-items" value="列出变更文件&#xa;列出通过的验证&#xa;说明剩余风险" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=14;spacingLeft=10;spacingTop=8;" parent="result" vertex="1">
